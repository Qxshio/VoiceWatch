{
  "manifest_version": 3,
  "name": "Voice Watch Connector",
  "description": "Connects Roblox voice chat status to the local Voice Watch desktop app.",
  "version": "0.1.0",
  "permissions": ["nativeMessaging", "storage"],
  "host_permissions": ["https://voice.roblox.com/*"],
  "background": {
    "service_worker": "service_worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Voice Watch",
    "default_popup": "connect.html"
  }
}
